# ── Application ───────────────────────────────────────────────────────────
APP_NAME=ScrumfolksTMS
APP_ENV=production
APP_DEBUG=false
APP_BASE_URL=https://tasks.scrumfolks.com
ALLOWED_HOSTS=tasks.scrumfolks.com,localhost,127.0.0.1,backend,frontend
ALLOWED_ORIGINS=https://tasks.scrumfolks.com,http://localhost:3000
TIMEZONE=Asia/Kolkata

# ── Security ──────────────────────────────────────────────────────────────
# Generate with:  python -c 'import secrets; print(secrets.token_urlsafe(48))'
JWT_SECRET=change-me-to-a-48-char-random-secret-string-please
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=10080  # 7 days

# Generate with:  python -c 'import secrets; print(secrets.token_urlsafe(32))'
CRON_SECRET=change-me-to-a-32-char-random-secret

# Cookie settings
COOKIE_NAME=sf_sess
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=tasks.scrumfolks.com

# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-to-a-strong-database-password
DATABASE_URL=postgresql+psycopg://tms:change-me-to-a-strong-database-password@postgres:5432/scrumfolks_tms
# 2-4 Gunicorn workers x pool 10 handles 50-60 concurrent users without
# overwhelming the local Postgres instance.
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=10

# ── Redis (rate limiting + scheduler lock) ────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Email (Resend preferred, SMTP fallback) ───────────────────────────────
EMAIL_PROVIDER=resend          # resend | smtp | console
EMAIL_FROM="Scrumfolks TMS <tms@scrumfolks.com>"
RESEND_API_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# ── AI (Anthropic Claude) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Scheduler ─────────────────────────────────────────────────────────────
ENABLE_SCHEDULER=true
DIGEST_HOUR=9
DIGEST_MINUTE=0
RISK_SCAN_HOUR=8
RISK_SCAN_MINUTE=0

# ── Seed / Bootstrap ───────────────────────────────────────────────────────
# Production: keep SEED_DEMO=false. The backend creates ONLY the first owner
# below, then you onboard everyone else from the in-app Team module.
SEED_DEMO=false
SEED_PASSWORD=scrumfolks2026

# First owner created on a clean database. Set a strong password before the
# first boot. Leave the password blank to skip bootstrap.
BOOTSTRAP_OWNER_NAME=Rushabh Shah
BOOTSTRAP_OWNER_EMAIL=owner@scrumfolks.com
BOOTSTRAP_OWNER_PASSWORD=change-me-strong-owner-password

# ── Concurrency (≈50-60 users) ──────────────────────────────────────────────
GUNICORN_WORKERS=3
WORKER_TIMEOUT=60
