# Next.js demo configuration

# MUST exactly match backend/.env JWT_SECRET so both servers verify the same cookie.
JWT_SECRET=scrumfolks-demo-jwt-secret-please-change-in-prod

# FastAPI backend endpoint (server-side fetches inside Next.js API routes).
FASTAPI_BASE_URL=http://127.0.0.1:8000

# Cron secret (must match backend/.env CRON_SECRET if you use the email cron).
CRON_SECRET=scrumfolks-demo-cron-secret
