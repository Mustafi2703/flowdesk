generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  id          String   @id
  title       String
  desc        String   @default("")
  brand       String
  assignedTo  String
  assignedBy  String
  priority    String
  due         DateTime
  status      String
  createdAt   DateTime
  timeline    Json

  @@map("tasks")
}
